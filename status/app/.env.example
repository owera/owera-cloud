# Public snapshot URL written by the operator plane (signed JSON, no auth).
# Defaults to the production object store if unset.
NEXT_PUBLIC_SNAPSHOT_URL=https://snapshots.owera.ai/health/latest.json

# When set to "1", the page renders a forced "all-down" snapshot. Used by the
# T19.4 acceptance test to simulate a gateway outage end-to-end without
# touching the operator plane. Production deploys leave this unset.
NEXT_PUBLIC_FORCE_INCIDENT=
